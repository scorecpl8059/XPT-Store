{
  "name": "xpt-store-backend",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "build": "tsc && cp package.json dist/ && cd dist && npm install --omit=dev --ignore-scripts",
    "dev": "tsc --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage"
  },
  "dependencies": {
    "@aws-sdk/client-dynamodb": "^3.1073.0",
    "@aws-sdk/client-s3": "^3.1073.0",
    "@aws-sdk/client-ses": "^3.1073.0",
    "@aws-sdk/lib-dynamodb": "^3.1073.0",
    "@aws-sdk/s3-request-presigner": "^3.1073.0",
    "@opensearch-project/opensearch": "^3.6.0",
    "bcryptjs": "^3.0.3",
    "jsonwebtoken": "^9.0.3",
    "qrcode": "^1.5.4",
    "sanitize-html": "^2.17.5",
    "speakeasy": "^2.0.0",
    "stripe": "^22.2.2",
    "ulid": "^3.0.2",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/aws-lambda": "^8.10.149",
    "@types/bcryptjs": "^2.4.6",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^20",
    "@types/qrcode": "^1.5.6",
    "@types/sanitize-html": "^2.16.1",
    "@types/speakeasy": "^2.0.10",
    "@vitest/coverage-v8": "^4.1.9",
    "typescript": "^5",
    "vitest": "^4.1.9"
  }
}
